<?xml version="1.0" encoding="UTF-8"?>
<Patch>
  <!-- 乌拉族初始任务 -->
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/StorytellerDef[@Name="BaseStoryteller"]/comps</xpath>
    <value>
      <li Class="EndfieldPerlica.StorytellerCompProperties_DaysAfterStart">
        <incident>EF_Perlica_Join</incident>
        <daysAfterStart>0.05</daysAfterStart>
        <delayTicks>1</delayTicks> <!-- 可选：触发后的延迟 -->
      </li>
    </value>
  </Operation>
</Patch>