<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <AbilityDef>
    <defName>EF_Perlica_LightingStrike</defName>
    <label>Protocol ω- Lightning Strike</label>
    <description>Release a beam of electromagnetic energy that falls from the sky, causing electromagnetic damage to enemies within a small range.</description>
    <iconPath>Endfield/UI/Abilities/EF_Perlica_LightingStrike</iconPath>
    <cooldownTicksRange>2400</cooldownTicksRange>
    <charges>3</charges>
    <cooldownPerCharge>true</cooldownPerCharge>
    <sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
    <aiCanUse>true</aiCanUse>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <label>Protocol ω - Lightning Strike</label>
      <drawAimPie>true</drawAimPie>
      <warmupTime>1.5</warmupTime>
      <range>20.9</range>
      <soundCast>EF_Perlica_LightingStrike_voice</soundCast>
      <targetParams>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetLocations>true</canTargetLocations>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="EndfieldPerlica.CompProperties_AbilityEF_LightingStrike">
        <explosionRadius>3.5</explosionRadius>
        <damageDef>Flame</damageDef>
        <damageAmount>35</damageAmount>
        <armorPenetration>0.85</armorPenetration>
        
        <!-- 自定义雷声 -->
        <thunderCameraSound>EF_Perlica_LightingStrike_Attack_Sound</thunderCameraSound>
        <thunderMapSound>EF_Perlica_LightingStrike_Attack_Sound</thunderMapSound>
      </li>
    </comps>
  </AbilityDef>
  <SoundDef>
    <defName>EF_Perlica_LightingStrike_Attack_Sound</defName>
    <context>MapOnly</context>
    <maxSimultaneous>2</maxSimultaneous>
    <subSounds>
      <li>
        <onCamera>True</onCamera>
        <grains>
          <li Class="AudioGrain_Clip">
            <clipPath>Endfield/EF_Perlica_LightingStrike_Attack_Sound</clipPath>
          </li>
        </grains>
        <volumeRange>75</volumeRange>
        <pitchRange>0.9~1.1</pitchRange>
      </li>
    </subSounds>
  </SoundDef>
  <SoundDef>
    <defName>EF_Perlica_LightingStrike_voice</defName>
    <context>MapOnly</context>
    <maxSimultaneous>3</maxSimultaneous>
    <subSounds>
      <li>
        <grains>
          <li Class="AudioGrain_Folder">
            <clipFolderPath>Endfield/EF_Perlica_LightingStrike</clipFolderPath>
          </li>
        </grains>
        <volumeRange>65</volumeRange>
        <!-- <muteWhenPaused>True</muteWhenPaused> -->
        <tempoAffectedByGameSpeed>false</tempoAffectedByGameSpeed>
      </li>
    </subSounds>
  </SoundDef>
  
  <AbilityDef>
    <defName>EF_Perlica_OrbitStrike</defName>
    <label>Protocol ε- 70.41K</label>
    <description>Immediately teleport a massive orbital floating object to deliver a devastating strike to the target area, causing significant damage to enemies within the area.</description>
    <iconPath>Endfield/UI/Abilities/EF_Perlica_7041K</iconPath>
    <cooldownTicksRange>12000</cooldownTicksRange>
    <sendMessageOnCooldownComplete>true</sendMessageOnCooldownComplete>
    <aiCanUse>true</aiCanUse>
    <casterMustBeCapableOfViolence>false</casterMustBeCapableOfViolence>
    <!-- <statBases>
      <Ability_EffectRadius>7</Ability_EffectRadius>
    </statBases> -->
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <label>Protocol ε - 70.41K</label>
      <drawAimPie>true</drawAimPie>
      <warmupTime>1.5</warmupTime>
      <range>36.9</range>
      <soundCast>EF_Perlica_OrbitStrike_voice</soundCast>
      <targetParams>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetLocations>true</canTargetLocations>
        <canTargetSelf>false</canTargetSelf>
      </targetParams>
    </verbProperties>
    <comps>
      <li Class="CompProperties_AbilitySpawn">
        <thingDef>EF_Perlica_OrbitTrash_Skyfaller</thingDef>
        <!-- <allowOnBuildings>False</allowOnBuildings> -->
      </li>
    </comps>
  </AbilityDef>
  <ThingDef ParentName="SkyfallerBase">
    <defName>EF_Perlica_OrbitTrash_Skyfaller</defName>
    <label>Orbit Trash</label>
    <size>(1, 1)</size>
    <graphicData>
      <texPath>Endfield/Mote/EF_Perlica_OrbitTrash_Skyfaller</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <!-- <shaderType>Transparent</shaderType> -->
      <drawSize>(10, 10)</drawSize>
    </graphicData>
    <skyfaller>
      <movementType>Accelerate</movementType>
      <shadow>Things/Skyfaller/SkyfallerShadowDropPod</shadow>
      <shadowSize>(3, 3)</shadowSize>
      <anticipationSound>DropPod_Fall</anticipationSound>
      <anticipationSoundTicks>100</anticipationSoundTicks>
      <impactSound>Explosion_Bomb</impactSound>
      <moteSpawnTime>0.05</moteSpawnTime>
      <motesPerCell>1</motesPerCell>
      <cameraShake>1</cameraShake>
      <explosionRadius>7</explosionRadius>
      <explosionDamage>EF_Perlica_OrbitTrash_Crush</explosionDamage>
      <explosionDamageFactor>1</explosionDamageFactor>
      <!-- <rotateGraphicTowardsDirection>true</rotateGraphicTowardsDirection> -->
      <speed>1.2</speed>
      <shadowSize>(5, 5)</shadowSize>
      <anticipationSound>DropPod_Fall</anticipationSound>
      <angleCurve>
        <points>
          <li>(0,-30)</li>
          <li>(1, -31)</li>
        </points>
      </angleCurve>
      <spawnThing>EF_Perlica_OrbitTrash</spawnThing>
    </skyfaller>
    <comps>
      <!-- <li Class="DivineDiurganate.CompProperties_PlaySoundOnSpawn">
        <sound>DD_Heavy_Air_bomb_Fire_Sound</sound>
      </li> -->
    </comps>
  </ThingDef>
  <ThingDef ParentName="BuildingBase">
    <defName>EF_Perlica_OrbitTrash</defName>
    <label>Orbit Trash</label>
    <description>A piece of space debris thrown down from the spacecraft "O.M.V.DiJiang" will generate a huge impact when it lands.</description>
    <thingClass>Building</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
    <graphicData>
      <texPath>Endfield/Mote/EF_Perlica_OrbitTrash</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(10, 10)</drawSize>
    </graphicData>
    <rotatable>false</rotatable>
    <passability>Impassable</passability>
    <blockWind>true</blockWind>
    <fillPercent>1</fillPercent>
    <blockLight>false</blockLight>
    <castEdgeShadows>false</castEdgeShadows>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <statBases>
      <MaxHitPoints>5000</MaxHitPoints>
      <WorkToBuild>2500</WorkToBuild>
      <Flammability>0</Flammability>
      <Beauty>-20</Beauty>
    </statBases>
    <tickerType>Normal</tickerType>
    <canOverlapZones>false</canOverlapZones>
    <size>(5,5)</size>
    <building>
      <isAirtight>false</isAirtight>
      <isStuffableAirtight>false</isStuffableAirtight>
      <destroySound>BuildingDestroyed_Metal_Medium</destroySound>
      <claimable>false</claimable>
    </building>
    <costList>
      <Steel>50</Steel>
    </costList>
    <damageMultipliers>
      <li>
        <damageDef>EF_Perlica_OrbitTrash_Crush</damageDef>
        <multiplier>0</multiplier>
      </li>
    </damageMultipliers>
  </ThingDef>
  <DamageDef>
    <defName>EF_Perlica_OrbitTrash_Crush</defName>
    <label>crush</label>
    <workerClass>DamageWorker_AddInjury</workerClass>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} has been crushed to death.</deathMessage>
    <hediff>Crush</hediff>
    <hediffSkin>Cut</hediffSkin>
    <hediffSolid>Crack</hediffSolid>
    <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
    <impactSoundType>Blunt</impactSoundType>
    <armorCategory>Blunt</armorCategory>
    <overkillPctToDestroyPart>0.4~1.0</overkillPctToDestroyPart>
    <buildingDamageFactor>10</buildingDamageFactor>
    <defaultDamage>50</defaultDamage>
    <defaultArmorPenetration>2</defaultArmorPenetration>
    <impactSoundType>MechBandShockwave</impactSoundType>
    <explosionCenterEffecter>EF_Perlica_OrbitTrash_Crush_Impact</explosionCenterEffecter>
    <explosionCellEffecter>MechBandElectricityArc</explosionCellEffecter>
    <explosionCellEffecterChance>0.1</explosionCellEffecterChance>
    <explosionCellEffecterMaxRadius>10</explosionCellEffecterMaxRadius>
    <soundExplosion>Explosion_MechBandShockwave</soundExplosion>
  </DamageDef>
  <EffecterDef>
    <defName>EF_Perlica_OrbitTrash_Crush_Impact</defName>
    <children>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>Fleck_BlastMechBandShockwave</fleckDef>
        <burstCount>1</burstCount>
        <spawnLocType>OnSource</spawnLocType>
        <absoluteAngle>true</absoluteAngle>
        <rotation>0~0</rotation>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <moteDef>Mote_GiantExplosion</moteDef>
        <scale>1~1</scale>
      </li>
      <li>
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <moteDef>Mote_GiantExplosionInner</moteDef>
        <scale>5~5</scale>
      </li>
    </children>
  </EffecterDef>
  <SoundDef>
    <defName>EF_Perlica_OrbitStrike_voice</defName>
    <context>MapOnly</context>
    <maxSimultaneous>3</maxSimultaneous>
    <subSounds>
      <li>
        <grains>
          <li Class="AudioGrain_Folder">
            <clipFolderPath>Endfield/EF_Perlica_OrbitStrike</clipFolderPath>
          </li>
        </grains>
        <volumeRange>65</volumeRange>
        <!-- <muteWhenPaused>True</muteWhenPaused> -->
        <tempoAffectedByGameSpeed>false</tempoAffectedByGameSpeed>
      </li>
    </subSounds>
  </SoundDef>
</Defs>