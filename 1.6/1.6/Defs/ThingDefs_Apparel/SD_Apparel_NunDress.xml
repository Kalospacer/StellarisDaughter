<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>SD_StellarUniform</defName>
    <label>星规-公式服</label>
    <description>A practical ceremonial dress adapted for field use. It offers modest protection and comfort, but remains cloth rather than true armor.</description>
    <graphicData>
      <texPath>StellarisDaughter/Things/SD/Clothes/SD_Cloth</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <generateCommonality>0.0001</generateCommonality>
    <costStuffCount>0</costStuffCount>
    <smeltable>false</smeltable>
    <useHitPoints>false</useHitPoints>
    <tradeTags Inherit="False"/>
    <tradeability>None</tradeability>
    <recipeMaker Inherit="False" IsNull="True"/>
    <thingCategories>
      <li>ApparelNoble</li>
    </thingCategories>
    <costList Inherit="False"/>
    <techLevel>Spacer</techLevel>
    <statBases>
			<WorkToMake>25000</WorkToMake>
			<Mass>0.5</Mass>
			<Flammability>0</Flammability>
			<EquipDelay>1</EquipDelay>
      <DeteriorationRate>0</DeteriorationRate>

      <ArmorRating_Blunt>1</ArmorRating_Blunt>
      <ArmorRating_Sharp>1</ArmorRating_Sharp>
      <ArmorRating_Heat>1</ArmorRating_Heat>
		</statBases>
    <equippedStatOffsets>
      <IncomingDamageFactor>-0.5</IncomingDamageFactor>
		</equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>FullHead</li>
				<li>Neck</li>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
      <renderSkipFlags>
        <li>None</li>
      </renderSkipFlags>
      <wornGraphicPath>StellarisDaughter/Things/SD/Clothes/SD_Cloth</wornGraphicPath>
      <layers>
        <li>OnSkin</li>
        <li>Middle</li>
      </layers>
      <tags>
        <li>SD_StellarWear</li>
      </tags>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(1,1,1,1)</only>
        </li>
      </options>
    </colorGenerator>
  </ThingDef>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>SD_StellarCloak</defName>
    <label>星规-披风</label>
    <description>A shell-layer cloak worn over the AI nun dress. It adds weather protection and a ceremonial silhouette for field duty.</description>
    <graphicData>
      <texPath>StellarisDaughter/Things/SD/Clothes/SD_Cloak</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>1.05</drawSize>
    </graphicData>
    <generateCommonality>0.0001</generateCommonality>
    <costStuffCount>0</costStuffCount>
    <smeltable>false</smeltable>
    <useHitPoints>false</useHitPoints>
    <tradeTags Inherit="False"/>
    <tradeability>None</tradeability>
    <recipeMaker Inherit="False" IsNull="True"/>
    <thingCategories>
      <li>ApparelNoble</li>
    </thingCategories>
    <costList Inherit="False"/>
    <techLevel>Spacer</techLevel>
    <statBases>
			<WorkToMake>25000</WorkToMake>
			<Mass>0.5</Mass>
			<Flammability>0</Flammability>
			<EquipDelay>1</EquipDelay>
      <DeteriorationRate>0</DeteriorationRate>

      <ArmorRating_Blunt>1</ArmorRating_Blunt>
      <ArmorRating_Sharp>1</ArmorRating_Sharp>
      <ArmorRating_Heat>1</ArmorRating_Heat>
		</statBases>
    <equippedStatOffsets>
      <IncomingDamageFactor>-0.5</IncomingDamageFactor>
		</equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
			</bodyPartGroups>
      <renderSkipFlags>
        <li>None</li>
      </renderSkipFlags>
      <wornGraphicPath>StellarisDaughter/Things/SD/Clothes/SD_Cloak</wornGraphicPath>
      <layers>
        <li>Shell</li>
      </layers>
      <tags>
        <li>SD_StellarWear</li>
      </tags>
      <drawData>
        <dataNorth>
            <layer>50</layer>
          </dataNorth>
      </drawData>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(1,1,1,1)</only>
        </li>
      </options>
    </colorGenerator>
    <comps>
      <li Class="CompProperties_CauseHediff_Apparel">
        <hediff>SD_Hediff_StellarCloak_BackSouth</hediff>
        <part>Torso</part>
      </li>
    </comps>
  </ThingDef>
</Defs>
