<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>SD_StellarUniform</defName>
    <label>stellar uniform</label>
    <description>A practical ceremonial dress adapted for field use. It offers modest protection and comfort, but remains cloth rather than true armor.</description>
    <graphicData>
      <texPath>StellarisDaughter/Things/SD/Clothes/SD_Cloth</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
    </graphicData>
    <costStuffCount>60</costStuffCount>
    <stuffCategories>
      <li>Leathery</li>
      <li>Fabric</li>
    </stuffCategories>
    <costList>
      <Cloth>30</Cloth>
    </costList>
    <techLevel>Industrial</techLevel>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <WorkToMake>25000</WorkToMake>
      <Mass>3</Mass>
      <Flammability>1</Flammability>
      <EquipDelay>1</EquipDelay>
      <StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0.40</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.40</StuffEffectMultiplierInsulation_Heat>
    </statBases>
    <equippedStatOffsets>
      <MedicalTendQuality>0.25</MedicalTendQuality>
      <MentalBreakThreshold>-0.1</MentalBreakThreshold>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Neck</li>
        <li>Torso</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>StellarisDaughter/Things/SD/Clothes/SD_Cloth</wornGraphicPath>
      <layers>
        <li>OnSkin</li>
        <li>Middle</li>
      </layers>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(1,1,1,1)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker>
      <researchPrerequisites>
        <li>HighClassClothing</li>
      </researchPrerequisites>
    </recipeMaker>
  </ThingDef>
  <ThingDef ParentName="ApparelMakeableBase">
    <defName>SD_StellarCloak</defName>
    <label>stellar cloak</label>
    <description>A shell-layer cloak worn over the AI nun dress. It adds weather protection and a ceremonial silhouette for field duty.</description>
    <possessionCount>1</possessionCount>
    <recipeMaker>
      <researchPrerequisite>ComplexClothing</researchPrerequisite>
      <displayPriority>215</displayPriority>
    </recipeMaker>
    <graphicData>
      <texPath>StellarisDaughter/Things/SD/Clothes/SD_Cloak</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>1.05</drawSize>
    </graphicData>
    <costStuffCount>80</costStuffCount>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <thingCategories>
      <li>ApparelMisc</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToMake>10000</WorkToMake>
      <Mass>2</Mass>
      <StuffEffectMultiplierArmor>0.3</StuffEffectMultiplierArmor>
      <StuffEffectMultiplierInsulation_Cold>0.60</StuffEffectMultiplierInsulation_Cold>
      <StuffEffectMultiplierInsulation_Heat>0.85</StuffEffectMultiplierInsulation_Heat>
      <EquipDelay>3</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.05</SlaveSuppressionOffset>
    </equippedStatOffsets>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
      </bodyPartGroups>
      <wornGraphicPath>StellarisDaughter/Things/SD/Clothes/SD_Cloak</wornGraphicPath>
      <layers>
        <li>Shell</li>
      </layers>
      <drawData>
        <dataNorth>
            <layer>50</layer>
          </dataNorth>
      </drawData>
      <tags>
        <li>IndustrialAdvanced</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
      </defaultOutfitTags>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(1,1,1,1)</only>
        </li>
      </options>
    </colorGenerator>
    <tradeTags>
      <li>BasicClothing</li>
    </tradeTags>
      <comps>
      <li Class="CompProperties_CauseHediff_Apparel">
        <hediff>SD_Hediff_StellarCloak_BackSouth</hediff>
        <part>Torso</part>
      </li>
    </comps>
  </ThingDef>
</Defs>