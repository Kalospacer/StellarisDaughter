<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <StellarisDaughter.SD_DroneTypeDef>
    <defName>SD_DroneType_Minipulser</defName>
    <droneDef>SD_Demo_DroneEntity</droneDef>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>SD_Bullet_Minipulser</defaultProjectile>
