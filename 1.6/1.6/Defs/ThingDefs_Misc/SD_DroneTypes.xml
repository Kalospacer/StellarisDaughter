        <minSpeed>1.2</minSpeed>
        <cutoffSpeed>0.2</cutoffSpeed>
        <uvScale>1.0</uvScale>
        <localOffset>(0, 0, -0.2)</localOffset>
        <widthCurve>
          <points>
            <li>(0, 0)</li>
            <li>(0.8, 1)</li>
            <li>(1, 0)</li>
          </points>
        </widthCurve>
        <alphaCurve>
