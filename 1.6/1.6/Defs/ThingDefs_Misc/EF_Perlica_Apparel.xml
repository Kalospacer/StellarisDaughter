<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="ApparelMakeableBase">
		<defName>EF_Perlica_Cloth</defName>
		<label>Perlica's Cloth</label>
    <description>The clothes worn by Perlica, the supervisor of Endfield.</description>
    <graphicData>
			<texPath>Endfield/Things/Perlica/Clothes/EF_Perlica_Cloth</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<costStuffCount>60</costStuffCount>
		<stuffCategories>
			<li>Leathery</li>
			<li>Fabric</li>
		</stuffCategories>
		<tradeTags Inherit="False"/>
		<thingCategories>
			<li>Apparel</li>
		</thingCategories>
    <apparel>
      <tags>
			  <li>EF_Perlica_Cloth</li>
      </tags>
			<bodyPartGroups>
				<li>Neck</li>
				<li>Torso</li>
				<li>Shoulders</li>
				<li>Arms</li>
				<li>Legs</li>
			</bodyPartGroups>
			<wornGraphicPath>Endfield/Things/Perlica/Clothes/EF_Perlica_Cloth</wornGraphicPath>
			<layers>
        <li>Middle</li>
			</layers>
      <canBeDesiredForIdeo>false</canBeDesiredForIdeo>
      <canBeGeneratedToSatisfyWarmth>false</canBeGeneratedToSatisfyWarmth>
      <canBeGeneratedToSatisfyToxicEnvironmentResistance>false</canBeGeneratedToSatisfyToxicEnvironmentResistance>
      <useWornGraphicMask>true</useWornGraphicMask>
    </apparel>
    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(1,1,1,1)</only>
        </li>
      </options>
    </colorGenerator>
    <recipeMaker Inherit="False"/>
    <costList>
      <Cloth>30</Cloth>
    </costList>
		<techLevel>Industrial</techLevel>
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<WorkToMake>25000</WorkToMake>
			<Mass>0.5</Mass>
			<Flammability>1</Flammability>
			<EquipDelay>1</EquipDelay>
      <StuffEffectMultiplierArmor>0.25</StuffEffectMultiplierArmor>
			<StuffEffectMultiplierInsulation_Cold>0.40</StuffEffectMultiplierInsulation_Cold>
			<StuffEffectMultiplierInsulation_Heat>0.40</StuffEffectMultiplierInsulation_Heat>
		</statBases>
		<equippedStatOffsets>
			<MedicalTendQuality>0.25</MedicalTendQuality>
      <MentalBreakThreshold>-0.1</MentalBreakThreshold>
		</equippedStatOffsets>
	</ThingDef>
</Defs>