<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>SD_Quest_AIDaughterCryptosleepCasket</defName>
    <label>stellaris cryptosleep casket</label>
    <description>A sealed cryptosleep casket carrying a dormant stellar regulator unit.</description>
    <thingClass>StellarisDaughter.Building_SDQuestCryptosleepCasket</thingClass>
    <containedPawnsSelectable>true</containedPawnsSelectable>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Things/Building/Ship/ShipCryptosleepCasket</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1, 2)</drawSize>
      <shadowData>
        <volume>(0.83, 0.3, 1.7)</volume>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>42</pathCost>
    <blockWind>true</blockWind>
    <fillPercent>0.5</fillPercent>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <Flammability>0.5</Flammability>
    </statBases>
    <tickerType>Normal</tickerType>
    <size>(1,2)</size>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(1,0,0)</interactionCellOffset>
    <defaultPlacingRot>South</defaultPlacingRot>
    <building>
      <ai_chillDestination>false</ai_chillDestination>
      <destroySound>BuildingDestroyed_Metal_Small</destroySound>
      <isPlayerEjectable>false</isPlayerEjectable>
    </building>
    <comps>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>2.66</explosiveRadius>
        <explosiveDamageType>Flame</explosiveDamageType>
      </li>
      <li Class="CompProperties_EmptyStateGraphic">
        <graphicData>
          <texPath>Things/Building/Ship/ShipCryptosleepCasketOpenDoor</texPath>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>(1, 2)</drawSize>
        </graphicData>
        <alwaysDrawParent>true</alwaysDrawParent>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
    <inspectorTabs>
      <li>ITab_ContentsCasket</li>
    </inspectorTabs>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <forceDebugSpawnable>true</forceDebugSpawnable>
  </ThingDef>
</Defs>
