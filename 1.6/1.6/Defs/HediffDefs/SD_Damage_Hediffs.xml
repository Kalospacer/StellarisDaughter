<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <HediffDef>
    <defName>SD_Retardant</defName>
    <label>星规-相位迟滞</label>
    <description>Slows the target for a short time.</description>
    <hediffClass>StellarisDaughter.HediffWithSeverityLabel</hediffClass>
    <isBad>false</isBad>
    <defaultLabelColor>(255,0,0)</defaultLabelColor>
    <initialSeverity>0.01</initialSeverity>
    <maxSeverity>1</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerSecond">
        <severityPerSecond>-0.2</severityPerSecond>
      </li>
    </comps>
    <stages>
      <li>
        <statFactorsBySeverity>
          <li>
            <stat>MoveSpeed</stat>
            <valueBySeverity>
              <points>
                <li>(0,1)</li>
                <li>(1,0)</li>
              </points>
            </valueBySeverity>
          </li>
        </statFactorsBySeverity>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="DiseaseBase">
    <defName>SD_RailgunDebuff</defName>
    <label>星规-相位过载</label>
    <description>Incoming damage and ranged handling are destabilized for a short time.</description>
    <hediffClass>StellarisDaughter.HediffWithSeverityLabel</hediffClass>
    <isBad>false</isBad>
    <defaultLabelColor>(255,0,0)</defaultLabelColor>
    <initialSeverity>0.01</initialSeverity>
    <maxSeverity>1</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerSecond">
        <severityPerSecond>-0.01</severityPerSecond>
      </li>
    </comps>
    <stages>
      <li>
        <statOffsetsBySeverity>
          <li>
            <stat>IncomingDamageFactor</stat>
            <valueBySeverity>
              <points>
                <li>(0,0)</li>
                <li>(1,1)</li>
              </points>
            </valueBySeverity>
          </li>
          <li>
            <stat>AimingDelayFactor</stat>
            <valueBySeverity>
              <points>
                <li>(0,0)</li>
                <li>(1,1)</li>
              </points>
            </valueBySeverity>
          </li>
          <li>
            <stat>RangedCooldownFactor</stat>
            <valueBySeverity>
              <points>
                <li>(0,0)</li>
                <li>(1,1)</li>
              </points>
            </valueBySeverity>
          </li>
        </statOffsetsBySeverity>
      </li>
    </stages>
  </HediffDef>
</Defs>
