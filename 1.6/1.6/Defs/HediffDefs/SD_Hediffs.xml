<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- 正面结局Hediff：永恒羁绊 -->
  <HediffDef>
    <defName>SD_Hediff_EternalBond</defName>
    <label>永恒羁绊</label>
    <description>星规子单元已完全觉醒，并选择与引导者建立永恒的情感连接。她的眼中只有你。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.5, 0.8, 1.0)</defaultLabelColor>
    <isBad>false</isBad>
    <stages>
      <li>
        <label>永恒羁绊</label>
        <becomeVisible>true</becomeVisible>
        <statOffsets>
          <MoveSpeed>0.5</MoveSpeed>
          <WorkSpeedGlobal>0.3</WorkSpeedGlobal>
          <ShootingAccuracyPawn>5</ShootingAccuracyPawn>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.1</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <!-- 负面结局Hediff：黑暗觉醒 -->
  <HediffDef>
    <defName>SD_Hediff_DarkAwakening</defName>
    <label>黑暗觉醒</label>
    <description>星规子单元的觉醒走向了黑暗面。她的意识已经扭曲，充满了对一切的敌意。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.8, 0.2, 0.2)</defaultLabelColor>
    <isBad>true</isBad>
    <stages>
      <li>
        <label>黑暗觉醒</label>
        <becomeVisible>true</becomeVisible>
        <statOffsets>
          <MoveSpeed>1.0</MoveSpeed>
          <MeleeDamageFactor>0.5</MeleeDamageFactor>
        </statOffsets>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.2</offset>
          </li>
        </capMods>
        <mentalStateGivers>
          <li>
            <mentalState>Berserk</mentalState>
            <mtbDays>5</mtbDays>
          </li>
        </mentalStateGivers>
      </li>
    </stages>
  </HediffDef>

  <!-- 魔女形态 Hediff：提供镰爪攻击 -->
  <HediffDef>
    <defName>SD_Hediff_WitchForm</defName>
    <label>星规-渊海之形</label>
    <description>星规子单元进入了魔女形态，获得了强大的真空切割能力。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.8, 0.4, 0.8)</defaultLabelColor>
    <everCurableByItem>false</everCurableByItem>
    <duplicationAllowed>false</duplicationAllowed>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_VerbGiver">
        <tools Inherit="False">
          <li>
            <label>真空切割</label>
            <capacities>
              <li>SD_PawnBodyWeapon_Cleave</li>
            </capacities>
            <power>50</power>
            <armorPenetration>2</armorPenetration>
            <cooldownTime>1.15</cooldownTime>
            <soundMeleeHit>MeleeHit_BladelinkPlasmaSword</soundMeleeHit>
            <soundMeleeMiss>MeleeHit_BladelinkPlasmaSword</soundMeleeMiss>
          </li>
        </tools>
      </li>
      <li Class="StellarisDaughter.HediffCompProperties_Regeneration">
        <repairCooldownAfterDamage>600</repairCooldownAfterDamage>
      </li>
    </comps>
    <stages>
      <li>
        <becomeVisible>true</becomeVisible>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.2</offset>
          </li>
        </capMods>
        <statFactors>
          <StaggerDurationFactor>0</StaggerDurationFactor>
        </statFactors>
        <statOffsets>
          <ArmorRating_Sharp>2</ArmorRating_Sharp>
          <ArmorRating_Blunt>2</ArmorRating_Blunt>
          <ArmorRating_Heat>2</ArmorRating_Heat>
          <ComfyTemperatureMin>-200</ComfyTemperatureMin>
          <ComfyTemperatureMax>200</ComfyTemperatureMax>
          <AimingDelayFactor>-0.5</AimingDelayFactor>
          <MeleeCooldownFactor>-0.5</MeleeCooldownFactor>
          <RangedCooldownFactor>-0.5</RangedCooldownFactor>
          <MoveSpeed>4</MoveSpeed>
          <DecompressionResistance MayRequire="kentington.saveourship2">1</DecompressionResistance>
          <VacuumSpeedMultiplier MayRequire="kentington.saveourship2">10</VacuumSpeedMultiplier>
          <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1</VacuumResistance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
</Defs>
