<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <DamageDef>
    <defName>SD_Retardant</defName>
    <label>retardant</label>
    <harmsHealth>false</harmsHealth>
    <makesBlood>false</makesBlood>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} was stunned to death.</deathMessage>
    <defaultDamage>20</defaultDamage>
    <defaultArmorPenetration>20</defaultArmorPenetration>
    <additionalHediffs>
      <li>
        <hediff>SD_Retardant</hediff>
        <severityFixed>0.2</severityFixed>
        <inverseStatScaling>true</inverseStatScaling>
        <victimSeverityScalingByInvBodySize>true</victimSeverityScalingByInvBodySize>
      </li>
    </additionalHediffs>
    <impactSoundType>Electric</impactSoundType>
  </DamageDef>

  <DamageDef>
    <defName>SD_SpearOfSRA_Burn</defName>
    <label>phase disintegration</label>
    <workerClass>DamageWorker_AddInjury</workerClass>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} was annihilated.</deathMessage>
    <hediff>Burn</hediff>
    <harmAllLayersUntilOutside>true</harmAllLayersUntilOutside>
    <impactSoundType>Bullet</impactSoundType>
    <soundExplosion>SD_Railgun_Explosion</soundExplosion>
    <armorCategory>Heat</armorCategory>
    <overkillPctToDestroyPart>0.9~1</overkillPctToDestroyPart>
    <isRanged>true</isRanged>
    <makesAnimalsFlee>true</makesAnimalsFlee>
    <defaultDamage>160</defaultDamage>
    <defaultArmorPenetration>4</defaultArmorPenetration>
    <buildingDamageFactorImpassable>10</buildingDamageFactorImpassable>
    <buildingDamageFactorPassable>10</buildingDamageFactorPassable>
    <ignoreShields>true</ignoreShields>
    <additionalHediffs>
      <li>
        <hediff>SD_RailgunDebuff</hediff>
        <severityPerDamageDealt>0.005</severityPerDamageDealt>
        <inverseStatScaling>true</inverseStatScaling>
        <victimSeverityScalingByInvBodySize>true</victimSeverityScalingByInvBodySize>
      </li>
    </additionalHediffs>
  </DamageDef>
</Defs>
